      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prototype": {
      "type": "string"
    },
    "header": {
      "type": "string"
    },
    "feature_macros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_function_attributes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operand_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "immediate_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "vectorization_role": {
      "type": "string"
    },
    "tail_policy": {
      "type": "string"
    },
